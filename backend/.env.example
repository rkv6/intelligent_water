# MongoDB Configuration
# For local development: mongodb://localhost:27017/intelligent-water
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/intelligent-water
MONGODB_URI=mongodb://localhost:27017/intelligent-water

# JWT Configuration
# Generate a strong random string for production
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Server Configuration
PORT=5000
NODE_ENV=development

# ThingSpeak Configuration
THINGSPEAK_BASE_URL=https://api.thingspeak.com

# ⚠️ SECURITY NOTICE ⚠️
# - NEVER commit the actual .env file to version control
# - .env must be in .gitignore
# - Use strong, unique secrets in production
# - Rotate JWT_SECRET periodically
# - Use environment-specific configurations
