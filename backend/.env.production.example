# Backend Configuration - Production Environment
# NEVER commit this file to version control!
# This is an EXAMPLE. Replace all values with your actual production secrets.

# Server Port
PORT=5000

# MongoDB Connection - Use MongoDB Atlas in production
# Format: mongodb+srv://username:password@cluster.mongodb.net/database-name
# Important: URL-encode special characters in password (@→%40, :→%3A)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/intelligent-water?retryWrites=true&w=majority

# JWT Secret Key - Generate using: openssl rand -base64 32
# Keep this secret and rotate periodically
JWT_SECRET=your-production-super-secret-jwt-key-here

# ThingSpeak API Base URL
THINGSPEAK_BASE_URL=https://api.thingspeak.com

# Environment
NODE_ENV=production

# ⚠️ CRITICAL SECURITY REMINDERS ⚠️
# 1. Never share or commit actual credentials
# 2. Use strong, unique passwords (minimum 16 characters)
# 3. Enable IP whitelist in MongoDB Atlas
# 4. Use HTTPS/TLS for all connections
# 5. Rotate secrets regularly
# 6. Use environment variables or secrets manager (e.g., AWS Secrets Manager, HashiCorp Vault)
# 7. Monitor and audit access logs
